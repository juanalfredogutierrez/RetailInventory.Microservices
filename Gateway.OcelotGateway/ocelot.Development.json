{
  "Routes": [

    {
      "DownstreamPathTemplate": "/api/auth/{everything}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "localhost",
          "Port": 5001
        }
      ],
      "UpstreamPathTemplate": "/auth/{everything}",
      "UpstreamHttpMethod": [ "POST"]
    },

    {
      "DownstreamPathTemplate": "/api/producto/{everything}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "localhost",
          "Port": 5003
        }
      ],
      "UpstreamPathTemplate": "/productos/{everything}",
      "UpstreamHttpMethod": [ "GET", "POST", "PUT"],
      "AuthenticationOptions": {
        "AuthenticationProviderKey": "Bearer"
      }
    },

    {
      "DownstreamPathTemplate": "/api/transaccion/{everything}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "localhost",
          "Port": 5004
        }
      ],
      "UpstreamPathTemplate": "/transacciones/{everything}",
      "UpstreamHttpMethod": ["POST"],
      "AuthenticationOptions": {
        "AuthenticationProviderKey": "Bearer"
      }
    },

    {
      "DownstreamPathTemplate": "/api/inventario/{everything}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "localhost",
          "Port": 5002
        }
      ],
      "UpstreamPathTemplate": "/inventario/{everything}",
      "UpstreamHttpMethod": [ "GET", "POST"],
      "AuthenticationOptions": {
        "AuthenticationProviderKey": "Bearer"
      }
    }

  ],

  "GlobalConfiguration": {
    "BaseUrl": "http://localhost:5000"
  },

  "Serilog": {
    "SeqUrl": "http://localhost:5341"
  }
}