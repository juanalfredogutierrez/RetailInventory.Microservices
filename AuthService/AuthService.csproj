<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>disable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
  </PropertyGroup>

  <ItemGroup>
    <Compile Remove="Application\Behaviors\**" />
    <Compile Remove="Application\DTOs\**" />
    <Compile Remove="Application\Queries\**" />
    <Compile Remove="Application\Validators\**" />
    <Content Remove="Application\Behaviors\**" />
    <Content Remove="Application\DTOs\**" />
    <Content Remove="Application\Queries\**" />
    <Content Remove="Application\Validators\**" />
    <EmbeddedResource Remove="Application\Behaviors\**" />
    <EmbeddedResource Remove="Application\DTOs\**" />
    <EmbeddedResource Remove="Application\Queries\**" />
    <EmbeddedResource Remove="Application\Validators\**" />
    <None Remove="Application\Behaviors\**" />
    <None Remove="Application\DTOs\**" />
    <None Remove="Application\Queries\**" />
    <None Remove="Application\Validators\**" />
  </ItemGroup>

  <ItemGroup>
